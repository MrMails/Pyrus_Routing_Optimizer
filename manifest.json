{
  "manifest_version": 3,
  "name": "Pyrus Routing Optimizer",
  "version": "1.5.3",
  "description": "Умная таблица маршрутизации прямо в Pyrus by Mr. Mails",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://pyrus.com/*", "*://*.pyrus.com/*"],
      "js": ["content.js"]
    }
  ]
}